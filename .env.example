# ==========================================
# Family Tree Builder - Email Configuration
# ==========================================

# Copy this file to a new file named `.env` in the same directory,
# and fill in either the Resend API or Gmail SMTP settings.

# ------------------------------------------
# OPTION 1: Resend API Configuration (Recommended)
# ------------------------------------------
# RESEND_API_KEY=re_123456789abcdef
# EMAIL_FROM=Family Tree <noreply@yourdomain.com>

# ------------------------------------------
# OPTION 2: Gmail SMTP Configuration
# ------------------------------------------
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your_gmail@gmail.com
# SMTP_PASSWORD=your_app_password
# EMAIL_FROM=your_gmail@gmail.com
